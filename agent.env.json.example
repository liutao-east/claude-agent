{
  "//": "复制为 agent.env.json 并填入真实值。结构与 ~/.claude/settings.json 的 env 块同构,可整块互相复制。",
  "//ignore-1": "agent.env.json 含密钥,已在 .gitignore 中忽略,勿提交。",
  "//ignore-2": "本块整体作为环境变量透传给 Agent 子进程(优先级高于本机 ~/.claude)。不需要的项可直接删除。",

  "env": {
    "ANTHROPIC_BASE_URL": "https://your-gateway.example.com",
    "ANTHROPIC_API_KEY": "sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx",

    "//model": "默认模型;场景未指定 model 时用此值。留空/删除 → 回退本机 ~/.claude 默认。",
    "ANTHROPIC_MODEL": "glm-5.1",

    "//alias": "别名解析:场景配 model:\"sonnet\"/\"opus\"/\"haiku\" 时,映射成这里的真实模型 ID(接第三方网关常用)。",
    "ANTHROPIC_DEFAULT_SONNET_MODEL": "glm-5-turbo",
    "ANTHROPIC_DEFAULT_OPUS_MODEL": "glm-5.1",
    "ANTHROPIC_DEFAULT_HAIKU_MODEL": "glm-5",

    "//proxy": "代理(可选,让 Agent 出站请求走代理)。",
    "HTTP_PROXY": "http://127.0.0.1:7897",
    "HTTPS_PROXY": "http://127.0.0.1:7897",
    "API_TIMEOUT_MS": "3000000",
    "CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC": "1"
  }
}
