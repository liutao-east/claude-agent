# ============================================================
# 代码问答服务环境变量示例
# 复制为 .env 并填入真实值后,用 `uv run --env-file .env python server.py` 启动
# ============================================================

# 模型网关地址:支持任意 Anthropic 协议兼容网关(留空则使用官方默认地址)
ANTHROPIC_BASE_URL=https://api.anthropic.com

# API Key
ANTHROPIC_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Agent 工作目录:被分析的项目代码所在路径(绝对路径)
PROJECT_DIR=/path/to/your/project

# 模型名称:需为你的网关支持的模型 ID,例如
#   claude-opus-4-8 / claude-sonnet-4-6 / 自定义网关模型名
MODEL=claude-sonnet-4-6

# ---- 可选 ----
# 监听地址与端口
# HOST=0.0.0.0
# PORT=8000
# 日志级别
# LOG_LEVEL=INFO
