{
  "//": "业务配置。网关/密钥/模型/代理等部署配置见同目录的 agent.env.json(agent.env.json.example 为模板)。",

  "//project_dir": "Agent 工作目录:被分析的项目代码绝对路径,只读模式下只能读取该目录下的文件",
  "project_dir": "D:/path/to/your/project",

  "//optional": "以下为可选项",
  "host": "0.0.0.0",
  "port": 8000,
  "log_level": "INFO",
  "db_path": "codeqa.db",

  "//default_scenario": "默认场景名;缺省时取 scenarios 列表首个,再缺省回退 code-qa",
  "default_scenario": "code-qa",

  "//scenarios": "可选的多场景配置。省略整个 scenarios 时会自动合成一个默认 code-qa 场景(用全局 project_dir/model + 内置代码问答提示词),旧配置无需改动。场景内 cwd/model/allowed_tools 省略则继承全局默认。",
  "scenarios": [
    {
      "name": "code-qa",
      "description": "代码问答:阅读理解项目代码并回答",
      "//prompt": "system_prompt_file 路径相对 server.py 目录解析;也可改用 system_prompt 内联字符串",
      "system_prompt_file": "scenarios/code_qa.md",
      "//guide": "可选:用户选中该场景后,在聊天区先显示的引导语(介绍用途+用法,支持 Markdown 与 ${VAR} 替换)。可用 guide 内联字符串,或 guide_file 指向相对 server.py 的 markdown 文件;省略则不显示引导。",
      "guide": "👋 这里能帮你读懂项目代码、解答实现相关的问题。\n\n**试着这样问:**\n- 某个功能的处理流程是怎样的?\n- 某段逻辑为什么这么写、有什么风险?"
    },
    {
      "name": "troubleshoot",
      "description": "项目问题排查:基于日志+代码定位线上问题",
      "system_prompt_file": "scenarios/troubleshoot.md",
      "//cwd": "代码目录;省略则用全局 project_dir",
      "cwd": "D:/path/to/your/project",
      "//model": "场景级覆盖(可选):填模型 ID 或别名(sonnet/opus/haiku)覆盖 agent.env.json 的 ANTHROPIC_MODEL;省略则用 ANTHROPIC_MODEL,再为空用本机默认",
      "model": "opus",
      "//scenario_env": "场景级 env(可选):覆盖 agent.env.json 全局 env 的同 key——如本场景换模型/网关/代理。注意与下方 mcp_servers.mysql.env 不同:那是给 MySQL 进程的,本字段是给 Agent 主进程的。省略则用全局 env。",
      "env": {
        "ANTHROPIC_MODEL": "glm-5.1",
        "API_TIMEOUT_MS": "6000000"
      },
      "//add_dirs": "cwd 之外允许访问的目录(日志目录 LOG_DIR),绝对路径",
      "add_dirs": ["/data/logs/neo-star"],
      "//allowed_tools": "接入 MySQL 查询后,需把 mcp__mysql__mysql_query 加进来,否则无头服务会因权限提示而挂起",
      "allowed_tools": ["Read", "Glob", "Grep", "Bash", "mcp__mysql__mysql_query"],
      "//vars": "提示词里 ${LOG_DIR}/${DATABASE} 等占位符的替换值",
      "vars": { "LOG_DIR": "/data/logs/neo-star", "DATABASE": "neo_star" },
      "//mcp_servers": "MySQL 只读查询:用 @benborla29/mcp-server-mysql 经 npx 启动;连接信息走 env;ALLOW_*_OPERATION 全置 false 即只读(仅 SELECT)。键名(mysql)对应工具前缀 mcp__mysql__*。Windows 下用 cmd /c 包一层 npx(如下);macOS/Linux 改为 command:'npx', args:['-y','@benborla29/mcp-server-mysql']。",
      "mcp_servers": {
        "mysql": {
          "command": "cmd",
          "args": ["/c", "npx", "-y", "@benborla29/mcp-server-mysql"],
          "env": {
            "MYSQL_HOST": "127.0.0.1",
            "MYSQL_PORT": "3306",
            "MYSQL_USER": "your-user",
            "MYSQL_PASS": "your-password",
            "MYSQL_DB": "neo_star",
            "ALLOW_INSERT_OPERATION": "false",
            "ALLOW_UPDATE_OPERATION": "false",
            "ALLOW_DELETE_OPERATION": "false"
          }
        }
      }
    }
  ]
}
